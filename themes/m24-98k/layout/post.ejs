<article class="post">
  <header class="post-header">
    <h1 class="post-title"><%= page.title %></h1>
    <div class="post-meta">
      <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
        </svg>
        <%= date(page.date, 'YYYY-MM-DD') %>
      </time>
      <% if (page.categories && page.categories.length) { %>
      <span class="category">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path fill="currentColor" d="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>
        </svg>
        <% page.categories.forEach(function(cat) { %>
        <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
        <% }); %>
      </span>
      <% } %>
      <% if (page.updated && page.updated !== page.date) { %>
      <span class="updated">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
        </svg>
        更新于 <%= date(page.updated, 'YYYY-MM-DD') %>
      </span>
      <% } %>
    </div>
  </header>
  
  <!-- TOC -->
  <% if (theme.post.toc && page.toc !== false) { %>
  <aside class="toc">
    <h4>目录</h4>
    <%- toc(page.content, {list_number: false}) %>
  </aside>
  <% } %>
  
  <div class="post-content">
    <%- page.content %>
  </div>
  
  <!-- Tags -->
  <% if (page.tags && page.tags.length) { %>
  <footer class="post-footer">
    <div class="post-tags">
      <svg viewBox="0 0 24 24" width="16" height="16">
        <path fill="currentColor" d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
      </svg>
      <% page.tags.forEach(function(tag) { %>
      <a href="<%= url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
      <% }); %>
    </div>
  </footer>
  <% } %>
  
  <!-- Comments -->
  <% if (page.comments !== false && theme.gitalk && theme.gitalk.enable) { %>
  <section class="comments">
    <h3>评论</h3>
    <div id="gitalk-container"></div>
  </section>
  <% } %>
  
  <!-- Navigation -->
  <nav class="post-nav">
    <% if (page.prev) { %>
    <a href="<%= url_for(page.prev.path) %>" class="prev">
      <span class="arrow">←</span>
      <span class="title"><%= page.prev.title %></span>
    </a>
    <% } %>
    <% if (page.next) { %>
    <a href="<%= url_for(page.next.path) %>" class="next">
      <span class="title"><%= page.next.title %></span>
      <span class="arrow">→</span>
    </a>
    <% } %>
  </nav>
</article>