<header class="header">
  <div class="header-container">
    <a href="<%= url_for('/') %>" class="logo">
      <span class="logo-text"><%= config.title %></span>
    </a>
    
    <button class="menu-toggle" aria-label="菜单">
      <span></span>
      <span></span>
      <span></span>
    </button>
    
    <nav class="nav">
      <% for (var name in theme.menu) { %>
      <a href="<%= url_for(theme.menu[name]) %>" class="nav-link<%= is_current(theme.menu[name]) ? ' active' : '' %>"><%= name %></a>
      <% } %>
    </nav>
    
    <% if (theme.search && theme.search.enable) { %>
    <div class="search-box">
      <input type="text" id="search-input" placeholder="<%= theme.search.placeholder %>" class="search-input">
      <button class="search-btn" aria-label="搜索">
        <svg viewBox="0 0 24 24" width="20" height="20">
          <path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
    </div>
    <% } %>
  </div>
</header>

<!-- Search Results Modal -->
<div id="search-modal" class="search-modal">
  <div class="search-modal-content">
    <span class="search-close">&times;</span>
    <h3>搜索结果</h3>
    <div id="search-results"></div>
  </div>
</div>