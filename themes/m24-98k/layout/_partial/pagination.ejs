<nav class="pagination">
  <% if (page.prev) { %>
  <a href="<%= url_for(page.prev_link) %>" class="prev">← 上一页</a>
  <% } %>
  
  <% var start = Math.max(1, page.current - 2); %>
  <% var end = Math.min(page.total, page.current + 2); %>
  
  <% if (start > 1) { %>
  <a href="<%= url_for('/') %>">1</a>
  <% if (start > 2) { %>
  <span class="gap">...</span>
  <% } %>
  <% } %>
  
  <% for (var i = start; i <= end; i++) { %>
  <% if (i === page.current) { %>
  <span class="current"><%= i %></span>
  <% } else { %>
  <a href="<%= url_for(i === 1 ? '/' : '/page/' + i + '/') %>"><%= i %></a>
  <% } %>
  <% } %>
  
  <% if (end < page.total) { %>
  <% if (end < page.total - 1) { %>
  <span class="gap">...</span>
  <% } %>
  <a href="<%= url_for('/page/' + page.total + '/') %>"><%= page.total %></a>
  <% } %>
  
  <% if (page.next) { %>
  <a href="<%= url_for(page.next_link) %>" class="next">下一页 →</a>
  <% } %>
</nav>