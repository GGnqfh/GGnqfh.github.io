<section class="category-page">
  <header class="category-page-header">
    <h1 class="category-page-title">分类：<%= page.category %></h1>
    <p class="category-page-count">共 <%= page.posts.length %> 篇文章</p>
    <a href="<%= url_for('/categories') %>" class="back-link">← 返回所有分类</a>
  </header>
  
  <div class="posts-list">
    <% page.posts.sort('date', -1).each(function(post) { %>
    <article class="post-card">
      <div class="post-meta">
        <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
      </div>
      <h3 class="post-title">
        <a href="<%= url_for(post.path) %>"><%= post.title %></a>
      </h3>
    </article>
    <% }); %>
  </div>
</section>