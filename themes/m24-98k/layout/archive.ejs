<section class="archive">
  <header class="archive-header">
    <h1 class="archive-title">归档</h1>
    <p class="archive-count">共 <%= site.posts.length %> 篇文章</p>
  </header>
  
  <div class="archive-list">
    <% var years = {}; %>
    <% site.posts.sort('date', -1).each(function(post) { %>
      <% var year = date(post.date, 'YYYY'); %>
      <% if (!years[year]) { years[year] = []; } %>
      <% years[year].push(post); %>
    <% }); %>
    
    <% Object.keys(years).sort().reverse().forEach(function(year) { %>
    <div class="archive-year">
      <h2 class="year-title"><%= year %></h2>
      <ul class="year-posts">
        <% years[year].forEach(function(post) { %>
        <li class="archive-post">
          <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MM-DD') %></time>
          <a href="<%= url_for(post.path) %>"><%= post.title %></a>
          <% if (post.categories && post.categories.length) { %>
          <span class="category">
            <a href="<%= url_for(post.categories.toArray()[0].path) %>"><%= post.categories.toArray()[0].name %></a>
          </span>
          <% } %>
        </li>
        <% }); %>
      </ul>
    </div>
    <% }); %>
  </div>
</section>