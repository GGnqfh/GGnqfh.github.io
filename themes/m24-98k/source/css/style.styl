/* M24!98K! Theme Styles */

/* Variables */
:root {
  --primary-color: #c00;
  --secondary-color: #333;
  --background-color: #f5f5f5;
  --text-color: #222;
  --link-color: #c00;
  --border-color: #ddd;
  --shadow-color: rgba(0, 0, 0, 0.1);
  --font-family: "Helvetica Neue", Helvetica, Arial, "Noto Sans SC", sans-serif;
}

/* Reset & Base */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-family);
  background: var(--background-color);
  color: var(--text-color);
  line-height: 1.6;
  min-height: 100vh;
}

a {
  color: var(--link-color);
  text-decoration: none;
  transition: color 0.2s;
}

a:hover {
  color: var(--primary-color);
}

img {
  max-width: 100%;
  height: auto;
}

/* Header */
.header {
  background: #fff;
  border-bottom: 1px solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.header-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
}

.logo {
  display: flex;
  align-items: center;
}

.logo-text {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--primary-color);
}

.nav {
  display: flex;
  gap: 1.5rem;
}

.nav-link {
  font-size: 1rem;
  color: var(--text-color);
  padding: 0.5rem 0;
  position: relative;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--primary-color);
  transition: width 0.2s;
}

.nav-link:hover::after,
.nav-link.active::after {
  width: 100%;
}

.nav-link.active {
  color: var(--primary-color);
}

/* Menu Toggle (Mobile) */
.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
}

.menu-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--text-color);
  transition: transform 0.2s;
}

/* Search Box */
.search-box {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.search-input {
  padding: 0.5rem 1rem;
  border: 1px solid var(--border-color);
  border-radius: 4px;
  font-size: 0.9rem;
  width: 200px;
  transition: border-color 0.2s;
}

.search-input:focus {
  outline: none;
  border-color: var(--primary-color);
}

.search-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-color);
  padding: 0.5rem;
}

.search-btn:hover {
  color: var(--primary-color);
}

/* Search Modal */
.search-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  justify-content: center;
  align-items: center;
}

.search-modal.active {
  display: flex;
}

.search-modal-content {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  max-width: 600px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.search-close {
  float: right;
  font-size: 1.5rem;
  cursor: pointer;
  color: var(--text-color);
}

.search-close:hover {
  color: var(--primary-color);
}

/* Main */
.main {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}

/* Banner */
.banner {
  text-align: center;
  padding: 3rem 0;
}

.banner-title {
  font-size: 4rem;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 1rem;
}

.banner-subtitle {
  font-size: 1.5rem;
  color: var(--secondary-color);
}

/* Weapons Gallery */
.weapons-gallery {
  margin: 2rem 0;
}

.section-title {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 1.5rem;
  text-align: center;
}

.gallery-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24px;
}

.gallery-item {
  width: 280px;
  text-align: center;
}

.gallery-item img {
  width: 100%;
  border: 4px solid var(--secondary-color);
  box-shadow: 0 4px 8px var(--shadow-color);
  transition: transform 0.2s, box-shadow 0.2s;
}

.gallery-item img:hover {
  transform: scale(1.02);
  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
}

.gallery-item .caption {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--primary-color);
  margin-top: 0.8rem;
}

/* Posts Section */
.posts-section {
  margin: 2rem 0;
}

.posts-list {
  display: grid;
  gap: 1.5rem;
}

.post-card {
  background: #fff;
  padding: 1.5rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
  transition: box-shadow 0.2s;
}

.post-card:hover {
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.85rem;
  color: #666;
  margin-bottom: 0.5rem;
}

.post-meta svg {
  vertical-align: middle;
}

.post-meta time {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.post-meta .category a {
  color: #666;
}

.post-meta .category a:hover {
  color: var(--primary-color);
}

.post-title {
  font-size: 1.25rem;
  margin-bottom: 0.5rem;
}

.post-title a {
  color: var(--text-color);
}

.post-title a:hover {
  color: var(--primary-color);
}

.post-excerpt {
  color: #666;
  font-size: 0.9rem;
  line-height: 1.5;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}

.tag {
  background: #eee;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.8rem;
  color: #666;
}

.tag:hover {
  background: var(--primary-color);
  color: #fff;
}

/* Post Page */
.post {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.post-header {
  margin-bottom: 2rem;
}

.post-title {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.9rem;
  color: #666;
}

.post-meta span {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

/* TOC */
.toc {
  background: #f9f9f9;
  padding: 1rem;
  border-radius: 4px;
  margin-bottom: 2rem;
}

.toc h4 {
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.toc ol {
  list-style: none;
}

.toc ol li {
  margin: 0.25rem 0;
}

.toc ol li a {
  color: #666;
  font-size: 0.9rem;
}

.toc ol li a:hover {
  color: var(--primary-color);
}

/* Post Content */
.post-content {
  line-height: 1.8;
}

.post-content h2 {
  font-size: 1.5rem;
  margin: 1.5rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border-color);
}

.post-content h3 {
  font-size: 1.25rem;
  margin: 1rem 0 0.5rem;
}

.post-content p {
  margin: 1rem 0;
}

.post-content ul,
.post-content ol {
  margin: 1rem 0;
  padding-left: 2rem;
}

.post-content li {
  margin: 0.25rem 0;
}

.post-content pre {
  background: #282c34;
  color: #abb2bf;
  padding: 1rem;
  border-radius: 4px;
  overflow-x: auto;
  margin: 1rem 0;
}

.post-content code {
  background: #eee;
  padding: 0.2rem 0.4rem;
  border-radius: 2px;
  font-size: 0.9em;
}

.post-content pre code {
  background: none;
  padding: 0;
}

.post-content blockquote {
  border-left: 4px solid var(--primary-color);
  padding-left: 1rem;
  margin: 1rem 0;
  color: #666;
}

.post-content img {
  display: block;
  margin: 1rem auto;
  border-radius: 4px;
}

.post-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
}

.post-content th,
.post-content td {
  border: 1px solid var(--border-color);
  padding: 0.5rem;
}

.post-content th {
  background: #f9f9f9;
}

/* Post Footer */
.post-footer {
  margin-top: 2rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-color);
}

.post-footer .post-tags {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.post-footer .post-tags svg {
  color: #666;
}

.post-footer .tag {
  background: var(--primary-color);
  color: #fff;
}

/* Comments */
.comments {
  margin-top: 2rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-color);
}

.comments h3 {
  font-size: 1.25rem;
  margin-bottom: 1rem;
}

/* Post Navigation */
.post-nav {
  display: flex;
  justify-content: space-between;
  margin-top: 2rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-color);
}

.post-nav a {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #666;
}

.post-nav a:hover {
  color: var(--primary-color);
}

.post-nav .arrow {
  font-size: 1.25rem;
}

/* Archive */
.archive {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.archive-header {
  text-align: center;
  margin-bottom: 2rem;
}

.archive-title {
  font-size: 2rem;
}

.archive-count {
  color: #666;
}

.archive-year {
  margin-bottom: 2rem;
}

.year-title {
  font-size: 1.5rem;
  color: var(--primary-color);
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--primary-color);
}

.year-posts {
  list-style: none;
}

.archive-post {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border-color);
}

.archive-post:last-child {
  border-bottom: none;
}

.archive-post time {
  color: #666;
  font-size: 0.9rem;
  min-width: 60px;
}

.archive-post a {
  color: var(--text-color);
}

.archive-post a:hover {
  color: var(--primary-color);
}

.archive-post .category {
  margin-left: auto;
}

.archive-post .category a {
  color: #666;
  font-size: 0.85rem;
}

/* Categories & Tags */
.category,
.tag {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.category-header,
.tag-header {
  text-align: center;
  margin-bottom: 2rem;
}

.category-title,
.tag-title {
  font-size: 2rem;
}

.category-count,
.tag-count {
  color: #666;
}

.category-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}

.category-item a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem;
  background: #f9f9f9;
  border-radius: 4px;
  color: var(--text-color);
}

.category-item a:hover {
  background: var(--primary-color);
  color: #fff;
}

.category-count {
  font-size: 0.9rem;
  color: #666;
}

.category-item a:hover .category-count {
  color: #fff;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.5rem 1rem;
  background: #f9f9f9;
  border-radius: 4px;
  color: var(--text-color);
}

.tag-item:hover {
  background: var(--primary-color);
  color: #fff;
}

.tag-count {
  font-size: 0.8em;
  color: #666;
}

.tag-item:hover .tag-count {
  color: #fff;
}

/* Tag Page & Category Page */
.tag-page,
.category-page {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.tag-page-header,
.category-page-header {
  margin-bottom: 2rem;
}

.back-link {
  display: inline-block;
  margin-top: 0.5rem;
  color: #666;
}

.back-link:hover {
  color: var(--primary-color);
}

/* Pagination */
.pagination {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  margin-top: 2rem;
}

.pagination a,
.pagination span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40px;
  height: 40px;
  padding: 0.5rem;
  background: #fff;
  border: 1px solid var(--border-color);
  border-radius: 4px;
  color: var(--text-color);
}

.pagination a:hover {
  background: var(--primary-color);
  color: #fff;
  border-color: var(--primary-color);
}

.pagination .current {
  background: var(--primary-color);
  color: #fff;
  border-color: var(--primary-color);
}

/* Footer */
.footer {
  background: #fff;
  border-top: 1px solid var(--border-color);
  padding: 2rem;
  margin-top: 2rem;
}

.footer-container {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.footer-info {
  margin-bottom: 1rem;
}

.copyright {
  color: #666;
  margin-bottom: 0.5rem;
}

.powered {
  color: #999;
  font-size: 0.85rem;
}

.powered a {
  color: #666;
}

.powered a:hover {
  color: var(--primary-color);
}

.social-links {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.social-links a {
  color: #666;
}

.social-links a:hover {
  color: var(--primary-color);
}

.thanks {
  font-size: 0.8rem;
  color: #666;
}

/* Page */
.page {
  background: #fff;
  padding: 2rem;
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.page-header {
  margin-bottom: 2rem;
}

.page-title {
  font-size: 2rem;
}

.page-content {
  line-height: 1.8;
}

/* Search Results */
.search-results-list {
  list-style: none;
  padding: 0;
}

.search-result-item {
  padding: 1rem;
  border-bottom: 1px solid var(--border-color);
}

.search-result-item:last-child {
  border-bottom: none;
}

.search-result-item a {
  color: var(--text-color);
}

.search-result-item a:hover {
  color: var(--primary-color);
}

.search-result-item h4 {
  font-size: 1.1rem;
  margin-bottom: 0.25rem;
}

.search-result-item p {
  color: #666;
  font-size: 0.9rem;
  line-height: 1.4;
}

/* Responsive */
@media (max-width: 768px) {
  .header-container {
    padding: 1rem;
  }
  
  .nav {
    display: none;
    flex-direction: column;
    width: 100%;
    gap: 0.5rem;
    padding: 1rem 0;
  }
  
  .nav.active {
    display: flex;
  }
  
  .menu-toggle {
    display: flex;
  }
  
  .search-box {
    width: 100%;
    margin-top: 1rem;
  }
  
  .search-input {
    width: 100%;
  }
  
  .banner-title {
    font-size: 2.5rem;
  }
  
  .banner-subtitle {
    font-size: 1.25rem;
  }
  
  .gallery-grid {
    flex-direction: column;
    align-items: center;
  }
  
  .gallery-item {
    width: 100%;
    max-width: 300px;
  }
  
  .main {
    padding: 1rem;
  }
  
  .post,
  .archive,
  .category,
  .tag,
  .page {
    padding: 1.5rem;
  }
  
  .post-title {
    font-size: 1.5rem;
  }
  
  .post-nav {
    flex-direction: column;
    gap: 1rem;
  }
  
  .archive-post {
    flex-wrap: wrap;
  }
  
  .archive-post .category {
    margin-left: 0;
    width: 100%;
    margin-top: 0.25rem;
  }
}

@media (max-width: 480px) {
  .banner-title {
    font-size: 2rem;
  }
  
  .section-title {
    font-size: 1.5rem;
  }
  
  .gallery-item .caption {
    font-size: 1.5rem;
  }
}